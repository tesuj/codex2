FORWARDER_HOST=127.0.0.1
FORWARDER_PORT=8787

# SMTP settings for email delivery
FORWARDER_SMTP_HOST=smtp.example.com
FORWARDER_SMTP_PORT=587
FORWARDER_SMTP_SECURE=false
FORWARDER_SMTP_USER=sender@example.com
FORWARDER_SMTP_PASS=your-password
FORWARDER_EMAIL_FROM=sender@example.com

# Telegram settings
# Use the bot token from BotFather. The bot name itself is not used in config.
FORWARDER_TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
FORWARDER_TELEGRAM_CHAT_ID=123456789
